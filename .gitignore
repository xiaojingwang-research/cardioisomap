# ---- Raw inputs (kept local; never committed) ----
data/raw/

# ---- Large rendered images (hosted separately via jsDelivr) ----
data/processed/sashimi/

# ---- Large genomics inputs (in case they land anywhere) ----
*.bam
*.bam.bai
*.gtf
*.gtf.gz

# ---- Local dev / tooling ----
.claude/
logs/
# personal maintenance cheat-sheet, kept local (not published)
docs/UPDATE_GUIDE.html

# ---- Python / OS cruft ----
__pycache__/
*.pyc
.DS_Store
.ipynb_checkpoints/
.venv/
venv/

# NOTE: data/processed/*.parquet and *.csv (incl. sashimi_manifest.csv) ARE
